# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# =============================================================================
# CONFIGURAÇÕES LOCAIS / SEGREDOS
